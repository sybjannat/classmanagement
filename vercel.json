{
  "version": 2,
  "builds": [
    {
      "src": "class.html",
      "use": "@vercel/static"
    },
    {
      "src": "manifest.json",
      "use": "@vercel/static"
    },
    {
      "src": "sw.js",
      "use": "@vercel/static"
    },
    {
      "src": "firebase-messaging-sw.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/class.html"
    },
    {
      "src": "/sw.js",
      "headers": {
        "Cache-Control": "no-cache",
        "Content-Type": "application/javascript; charset=utf-8"
      },
      "dest": "/sw.js"
    },
    {
      "src": "/firebase-messaging-sw.js",
      "headers": {
        "Cache-Control": "no-cache",
        "Content-Type": "application/javascript; charset=utf-8"
      },
      "dest": "/firebase-messaging-sw.js"
    },
    {
      "src": "/manifest.json",
      "headers": {
        "Cache-Control": "public, max-age=86400",
        "Content-Type": "application/json; charset=utf-8"
      },
      "dest": "/manifest.json"
    },
    {
      "src": "/(.*)",
      "dest": "/class.html"
    }
  ]
}
